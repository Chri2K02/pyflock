# Connection strings
PYFLOCK_REDIS_URL=redis://localhost:6379/0
PYFLOCK_DATABASE_URL=postgresql+psycopg://pyflock:pyflock@localhost:5432/pyflock

# API
PYFLOCK_API_HOST=0.0.0.0
PYFLOCK_API_PORT=8000
# Used by the CLI to reach the control plane
PYFLOCK_API_URL=http://localhost:8000

# Worker
PYFLOCK_WORKER_CONCURRENCY=4
PYFLOCK_JOB_DEFAULT_TIMEOUT=300

# Heartbeats / liveness (seconds)
PYFLOCK_HEARTBEAT_INTERVAL=3
PYFLOCK_HEARTBEAT_TTL=10

# Scheduler / retries
PYFLOCK_REAPER_INTERVAL=5
PYFLOCK_MAX_ATTEMPTS=3
PYFLOCK_BACKOFF_BASE=2.0
PYFLOCK_BACKOFF_CAP=60.0
